<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- 1. توجيه بروكسي GeoServer إلى Node (الأولوية القصوى قبل قاعدة الملفات الثابتة) -->
        <rule name="GeoServer Proxy" stopProcessing="true">
          <match url="^geoserver-proxy/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3000/geoserver-proxy/{R:1}" />
        </rule>

        <!-- 2. توجيه مسارات الـ API إلى Node -->
        <rule name="API Routes" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3000/api/{R:1}" />
        </rule>

        <!-- 2.5 توجيه مسار تسجيل الإحصائيات إلى Node -->
        <rule name="Save Stat Route" stopProcessing="true">
          <match url="^save-stat" />
          <action type="Rewrite" url="http://127.0.0.1:3000/save-stat" />
        </rule>

        <!-- 3. الملفات الثابتة الحقيقية فقط (يجب أن تكون موجودة فعلياً على القرص) -->
        <rule name="Static Files" stopProcessing="true">
          <match url=".*\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- 4. توجيه لوحة التحكم dashboard.html -->
        <rule name="Dashboard" stopProcessing="true">
          <match url="^dashboard(?:\.html)?$" />
          <action type="Rewrite" url="dashboard.html" />
        </rule>

        <!-- 5. أي طلب آخر غير موجود كملف/مجلد يذهب إلى index.html -->
        <rule name="SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- تمرير أخطاء Node/GeoServer كما هي (JSON) بدل استبدالها بصفحات IIS -->
    <httpErrors existingResponse="PassThrough" />

    <security>
      <requestFiltering>
        <requestLimits maxUrl="8192" maxQueryString="8192" maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
