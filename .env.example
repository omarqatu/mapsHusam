# إعدادات السيرفر
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=1

# إعدادات قاعدة البيانات
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
SERVICES_DB_NAME=services_db
REAL_ESTATE_DB_NAME=realestate

# إعدادات GeoServer
GEOSERVER_TARGET=http://your-geoserver-host:8080/geoserver
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=geoserver

# إعدادات CORS (اختياري - للسماح بمصادر إضافية)
ALLOWED_ORIGINS=https://psm.alameenapps.com,http://psm.alameenapps.com
ALLOW_ALL_ORIGINS=false
